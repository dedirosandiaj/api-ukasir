generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model merchants {
  token_number     String    @id @db.VarChar(255)
  order_id         String?   @unique @db.VarChar(255)
  name             String    @db.VarChar(255)
  merchant_name    String?   @db.VarChar(255)
  email            String    @db.VarChar(255)
  phone            String    @db.VarChar(20)
  province         String?   @db.VarChar(100)
  city             String?   @db.VarChar(100)
  district         String?   @db.VarChar(100)
  subdistrict      String?   @db.VarChar(100)
  postal_code      String?   @db.VarChar(10)
  street_address   String?   @db.VarChar(500)
  package          String?   @db.VarChar(50)
  amount           Decimal   @default(0) @db.Decimal(12, 2)
  status           String    @default("pending") @db.VarChar(50)
  payment_method   String?   @db.VarChar(50)
  payment_url      String?   @db.VarChar(500)
  payment_status   String    @default("pending") @db.VarChar(50)
  midtrans_order_id String?  @db.VarChar(255)
  paid_at          DateTime? @db.Timestamptz(6)
  register_date    DateTime  @default(now()) @db.Timestamp(6)
  status_active    Boolean   @default(false)
  device_id        String?   @db.VarChar(255)
  device_name      String?   @db.VarChar(255)
  device_type      String?   @db.VarChar(255)
  referral_code    String?   @db.VarChar(255)
  exclusive_merchant Int?    @unique
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)
}

model product {
  id               String    @id @default(uuid()) @db.Uuid
  name             String    @unique @db.VarChar(255)
  slug             String    @unique @db.VarChar(255)
  price            Decimal   @db.Decimal(12, 2)
  photo_url        String?   @db.VarChar(500)
  description      String?   @db.Text
  status           String    @default("active") @db.VarChar(50)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)

  @@index([slug])
  @@index([status])
}

model notifications {
  id           String    @id @default(uuid()) @db.Uuid
  title        String    @db.VarChar(255)
  body         String    @db.Text
  type         String    @default("info") @db.VarChar(50)
  target_type  String    @default("broadcast") @db.VarChar(50)
  token_number String?   @db.VarChar(255)
  status       String    @default("scheduled") @db.VarChar(50) // scheduled, draft, inactive
  scheduled_at DateTime  @default(now()) @db.Timestamptz(6)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @db.Timestamptz(6)

  @@index([type])
  @@index([target_type])
  @@index([token_number])
  @@index([status])
  @@index([scheduled_at])
}

model notification_reads {
  id              String   @id @default(uuid()) @db.Uuid
  notification_id String   @db.Uuid
  token_number    String   @db.VarChar(255)
  read_at         DateTime @default(now()) @db.Timestamptz(6)

  @@unique([notification_id, token_number])
  @@index([token_number])
}

model bank_ewallets {
  id           String   @id @default(uuid()) @db.Uuid
  account_name String   @db.VarChar(255)
  account_type String   @db.VarChar(50) // bank or e-wallet
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @default(now()) @db.Timestamptz(6)
}

model qris_activations {
  id                       String   @id @default(uuid()) @db.Uuid
  token_number             String   @db.VarChar(255)
  account_name             String   @db.VarChar(255)
  account_name_owner       String   @db.VarChar(255)
  account_number_owner     String   @db.VarChar(100)
  attachment_account_book  String   @db.VarChar(500)
  attachment_identity_card String   @db.VarChar(500)
  agree_terms              Boolean  @default(false)
  status                   String   @default("pending") @db.VarChar(50) // pending, approved, rejected
  created_at               DateTime @default(now()) @db.Timestamptz(6)
  updated_at               DateTime @default(now()) @db.Timestamptz(6)

  @@index([token_number])
  @@index([status])
}

model cashier_transactions {
  id             String   @id @default(uuid()) @db.Uuid
  order_id       String   @unique @db.VarChar(255)
  token_number   String   @db.VarChar(255)
  gross_amount   Decimal  @db.Decimal(12, 2)
  payment_status String   @default("pending") @db.VarChar(50) // pending, paid, failed, expired
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)

  @@index([token_number])
  @@index([payment_status])
}
model withdrawals {
  id             String   @id @default(uuid()) @db.Uuid
  token_number   String   @db.VarChar(255)
  amount         Decimal  @db.Decimal(12, 2)
  status         String   @default("pending") @db.VarChar(50) // pending, approved, rejected, completed
  bank_name      String   @db.VarChar(255)
  account_number String   @db.VarChar(100)
  account_name   String   @db.VarChar(255)
  reason         String?  @db.VarChar(500)
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)

  @@index([token_number])
  @@index([status])
}
