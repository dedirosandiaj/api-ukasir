generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model merchants {
  token_number     String    @id @db.VarChar(255)
  order_id         String?   @unique @db.VarChar(255)
  name             String    @db.VarChar(255)
  merchant_name    String?   @db.VarChar(255)
  email            String    @db.VarChar(255)
  phone            String    @db.VarChar(20)
  address          String?   @db.VarChar(500)
  city             String?   @db.VarChar(100)
  subdistrict      String?   @db.VarChar(100)
  regency          String?   @db.VarChar(100)
  province         String?   @db.VarChar(100)
  postal_code      String?   @db.VarChar(10)
  package          String?   @db.VarChar(50)
  amount           Decimal   @default(0) @db.Decimal(12, 2)
  status           String    @default("pending") @db.VarChar(50)
  payment_method   String?   @db.VarChar(50)
  payment_url      String?   @db.VarChar(500)
  payment_status   String    @default("pending") @db.VarChar(50)
  midtrans_order_id String?  @db.VarChar(255)
  paid_at          DateTime? @db.Timestamptz(6)
  register_date    DateTime  @default(now()) @db.Timestamp(6)
  status_active    Boolean   @default(false)
  device_id        String?   @db.VarChar(255)
  device_name      String?   @db.VarChar(255)
  device_type      String?   @db.VarChar(255)
  referral_code    String?   @db.VarChar(255)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)
}

model product {
  id               String    @id @default(uuid()) @db.Uuid
  name             String    @unique @db.VarChar(255)
  slug             String    @unique @db.VarChar(255)
  price            Decimal   @db.Decimal(12, 2)
  photo_url        String?   @db.VarChar(500)
  description      String?   @db.Text
  status           String    @default("active") @db.VarChar(50)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)

  @@index([slug])
  @@index([status])
}

model notifications {
  id           String    @id @default(uuid()) @db.Uuid
  title        String    @db.VarChar(255)
  body         String    @db.Text
  type         String    @default("info") @db.VarChar(50)
  target_type  String    @default("broadcast") @db.VarChar(50)
  token_number String?   @db.VarChar(255)
  status       String    @default("scheduled") @db.VarChar(50)
  scheduled_at DateTime  @default(now()) @db.Timestamptz(6)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @db.Timestamptz(6)

  @@index([type])
  @@index([target_type])
  @@index([token_number])
  @@index([status])
  @@index([scheduled_at])
}

model notification_reads {
  id              String   @id @default(uuid()) @db.Uuid
  notification_id String   @db.Uuid
  token_number    String   @db.VarChar(255)
  read_at         DateTime @default(now()) @db.Timestamptz(6)

  @@unique([notification_id, token_number])
  @@index([token_number])
}

